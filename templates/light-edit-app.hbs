<form class="tle-light-edit-form flexcol" autocomplete="off">
  {{!-- Light ID --}}
  <div class="form-group">
    <label>Light ID</label>
    <div class="form-fields">
      <input type="text" name="lightId" value="{{lightId}}" {{#if isBuiltin}}readonly{{/if}} placeholder="unique-id" required>
    </div>
    <p class="hint">Unique identifier. Items reference this to grant access to the light.</p>
  </div>

  {{!-- Emission --}}
  <fieldset class="tle-fieldset">
    <legend>Emission</legend>

    <div class="form-group">
      <label>Bright Radius</label>
      <div class="form-fields">
        <input type="number" name="light.bright" value="{{light.bright}}" min="0" step="0.5" placeholder="0">
      </div>
    </div>

    <div class="form-group">
      <label>Dim Radius</label>
      <div class="form-fields">
        <input type="number" name="light.dim" value="{{light.dim}}" min="0" step="0.5" placeholder="0">
      </div>
    </div>

    <div class="form-group">
      <label>Emission Angle</label>
      <div class="form-fields">
        <input type="number" name="light.angle" value="{{light.angle}}" min="0" max="360" step="1">
      </div>
      <p class="hint">0–360 degrees. 360 = full circle.</p>
    </div>
  </fieldset>

  {{!-- Color --}}
  <fieldset class="tle-fieldset">
    <legend>Color</legend>

    <div class="form-group">
      <label>Light Color</label>
      <div class="form-fields tle-color-row">
        <input type="text" name="light.color" value="{{light.color}}" placeholder="#ffffff" maxlength="7">
        <input type="color" value="{{light.color}}" data-edit="light.color" title="Pick Color">
      </div>
    </div>

    <div class="form-group">
      <label>Color Intensity</label>
      <div class="form-fields tle-range-row">
        <input type="range" name="light.alpha" value="{{light.alpha}}" min="0" max="1" step="0.05">
        <span class="tle-range-value">{{light.alpha}}</span>
      </div>
    </div>

    <div class="form-group">
      <label>Luminosity</label>
      <div class="form-fields tle-range-row">
        <input type="range" name="light.luminosity" value="{{light.luminosity}}" min="-1" max="1" step="0.05">
        <span class="tle-range-value">{{light.luminosity}}</span>
      </div>
    </div>
  </fieldset>

  {{!-- Visual Effects --}}
  <fieldset class="tle-fieldset">
    <legend>Visual Effects</legend>

    <div class="form-group">
      <label>Gradual Illumination</label>
      <div class="form-fields tle-range-row">
        <input type="range" name="light.attenuation" value="{{light.attenuation}}" min="0" max="1" step="0.05">
        <span class="tle-range-value">{{light.attenuation}}</span>
      </div>
    </div>

    <div class="form-group">
      <label>Coloration Technique</label>
      <div class="form-fields">
        <select name="light.coloration">
          {{#each colorationTechniques}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>Saturation</label>
      <div class="form-fields tle-range-row">
        <input type="range" name="light.saturation" value="{{light.saturation}}" min="-1" max="1" step="0.05">
        <span class="tle-range-value">{{light.saturation}}</span>
      </div>
    </div>

    <div class="form-group">
      <label>Contrast</label>
      <div class="form-fields tle-range-row">
        <input type="range" name="light.contrast" value="{{light.contrast}}" min="-1" max="1" step="0.05">
        <span class="tle-range-value">{{light.contrast}}</span>
      </div>
    </div>

    <div class="form-group">
      <label>Shadows</label>
      <div class="form-fields tle-range-row">
        <input type="range" name="light.shadows" value="{{light.shadows}}" min="0" max="1" step="0.05">
        <span class="tle-range-value">{{light.shadows}}</span>
      </div>
    </div>
  </fieldset>

  {{!-- Darkness --}}
  <fieldset class="tle-fieldset">
    <legend>Darkness Activation Range</legend>
    <div class="form-group">
      <label>Minimum</label>
      <div class="form-fields">
        <input type="number" name="light.darkness.min" value="{{light.darkness.min}}" min="0" max="1" step="0.05">
      </div>
    </div>
    <div class="form-group">
      <label>Maximum</label>
      <div class="form-fields">
        <input type="number" name="light.darkness.max" value="{{light.darkness.max}}" min="0" max="1" step="0.05">
      </div>
    </div>
  </fieldset>

  {{!-- Animation --}}
  <fieldset class="tle-fieldset">
    <legend>Animation</legend>

    <div class="form-group">
      <label>Animation Type</label>
      <div class="form-fields">
        <select name="light.animation.type">
          {{#each animationTypes}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>Speed</label>
      <div class="form-fields tle-range-row">
        <input type="range" name="light.animation.speed" value="{{light.animation.speed}}" min="1" max="10" step="1">
        <span class="tle-range-value">{{light.animation.speed}}</span>
      </div>
    </div>

    <div class="form-group">
      <label>Intensity</label>
      <div class="form-fields tle-range-row">
        <input type="range" name="light.animation.intensity" value="{{light.animation.intensity}}" min="1" max="10" step="1">
        <span class="tle-range-value">{{light.animation.intensity}}</span>
      </div>
    </div>

    <div class="form-group">
      <label>Reverse Direction</label>
      <div class="form-fields">
        <input type="checkbox" name="light.animation.reverse" {{checked light.animation.reverse}}>
      </div>
    </div>
  </fieldset>

  {{!-- Advanced --}}
  <fieldset class="tle-fieldset">
    <legend>Advanced</legend>

    <div class="form-group">
      <label>Negative Light</label>
      <div class="form-fields">
        <input type="checkbox" name="light.negative" {{checked light.negative}}>
      </div>
      <p class="hint">Acts as a darkness source instead of a light source.</p>
    </div>

    <div class="form-group">
      <label>Priority</label>
      <div class="form-fields">
        <input type="number" name="light.priority" value="{{light.priority}}" min="0" step="1">
      </div>
    </div>
  </fieldset>

  <footer class="sheet-footer flexrow">
    <button type="submit" class="tle-btn-save">
      <i class="fa-solid fa-floppy-disk"></i> Save
    </button>
    <button type="button" data-action="cancel" class="tle-btn-cancel">
      <i class="fa-solid fa-xmark"></i> Cancel
    </button>
  </footer>
</form>
